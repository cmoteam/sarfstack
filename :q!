{
  "permissions": {
    "allow": [
      "Write(output/**)",
      "Edit(output/**)",
      "Write(memory/profile/**)",
      "Edit(memory/profile/**)",
      "Write(memory/results/**)",
      "Edit(memory/results/**)",
      "Write(knowledge/update/**)",
      "Edit(knowledge/update/**)",
      "Write(memory/workspaces/**)",
      "Edit(memory/workspaces/**)",
      "Write(memory/organization/**)",
      "Edit(memory/organization/**)",
      "Write(knowledge/base/**)",
      "Edit(knowledge/base/**)"
    ],
    "deny": [
      "Write(memory/profile.example/**)",
      "Edit(memory/profile.example/**)",
      "Write(memory/results.example/**)",
      "Edit(memory/results.example/**)",
      "Write(memory/organization.example/**)",
      "Edit(memory/organization.example/**)",
      "Write(.mcp.json)",
      "Read(.mcp.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-protected-paths.sh"
          }
        ]
      }
    ]
  },
