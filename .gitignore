# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Node (if used for tooling)
node_modules/

# Per-workspace memory (not shared upstream).
# Structure: memory/workspaces/<slug>/{profile,results}/
# Active workspace is selected by the memory/profile and memory/results symlinks,
# so all skills (Read: memory/profile/...) work transparently.
# Bootstrap: /workspace new <slug>  or  /workspace switch <slug>
memory/workspaces/
memory/profile
memory/results

# Organization-wide memory (single instance, not shared upstream).
# Contains mission / brand / org-level overview that applies across all workspaces.
# Bootstrap: /set-organization  (copies from memory/organization.example/ on first run)
memory/organization/

# Generated artifacts (per-project outputs; not shared upstream)
# All skills write their deliverables under output/
output/*
!output/.gitkeep
!output/README.md

# MCP server config: may contain API keys / tokens for third-party integrations
# Bootstrap with: cp .mcp.json.example .mcp.json
# See knowledge/foundation/integrations.md
.mcp.json
.claude/settings.local.json
