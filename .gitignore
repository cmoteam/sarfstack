# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Node (if used for tooling)
node_modules/

# Python bytecode (bin/*.py)
__pycache__/
*.pyc

# Private data: organization memory + workspace data + generated artifacts.
#
# Convention: private/ is a SEPARATE PRIVATE REPO per company, cloned into this
# directory. Not registered as a git submodule because the URL differs per
# company and upstream cannot pin a specific private repo.
#
# Bootstrap: git clone <your-company-private-repo> private
# See README.md §Setup step 2 for details.
/private/

# MCP server config: may contain API keys / tokens for third-party integrations
# Bootstrap with: cp .mcp.json.example .mcp.json
# See knowledge/foundation/integrations.md
.mcp.json
.claude/settings.local.json
